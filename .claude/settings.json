{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bundle exec rspec *)",
      "Bash(bin/rubocop *)",
      "Bash(bin/brakeman *)",
      "Bash(bin/importmap audit*)",
      "Bash(bundle exec bundler-audit *)",
      "Bash(bin/rails db:migrate*)",
      "Bash(bin/rails db:prepare*)",
      "Bash(bin/rails generate *)",
      "Bash(bin/rails g *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Read(./config/master.key)",
      "Read(./config/credentials.yml.enc)",
      "Read(./config/credentials/**)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/*.pem)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push *main*)",
      "Bash(curl *)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path'); [[ \"$FILE\" == *.rb ]] && bin/rubocop --format quiet \"$FILE\"; true"
          }
        ]
      }
    ]
  }
}
