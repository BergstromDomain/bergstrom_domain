<%# app/views/event_types/_form.html.erb %>

<%= form_with model: event_type, class: "resource-form" do |f| %>
  <% if event_type.errors.any? %>
    <div class="form-errors" data-testid="form-errors">
      <p><%= pluralize(event_type.errors.count, "error") %> prevented this event type from being saved:</p>
      <ul>
        <% event_type.errors.each do |error| %>
          <li data-testid="field-error"><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name,
          class: "form-control #{'form-control--error' if event_type.errors[:name].any?}",
          data: { testid: "name-field" } %>
    <% if event_type.errors[:name].any? %>
      <span class="field-error" data-testid="field-error">
        <%= event_type.errors[:name].first %>
      </span>
    <% end %>
  </div>

  <div class="form-group">
    <%= f.label :description %>
    <%= f.text_area :description,
          rows: 4,
          class: "form-control #{'form-control--error' if event_type.errors[:description].any?}",
          data: { testid: "description-field" } %>
    <% if event_type.errors[:description].any? %>
      <span class="field-error" data-testid="field-error">
        <%= event_type.errors[:description].first %>
      </span>
    <% end %>
  </div>

  <div class="form-group">
    <%= f.label :icon %>
    <%= f.text_field :icon,
          placeholder: "e.g. music, cake, trophy",
          class: "form-control #{'form-control--error' if event_type.errors[:icon].any?}",
          data: { testid: "icon-field" } %>
    <% if event_type.errors[:icon].any? %>
      <span class="field-error" data-testid="field-error">
        <%= event_type.errors[:icon].first %>
      </span>
    <% end %>
    <p class="form-hint">
      Find icon names at <%= link_to "lucide.dev/icons", "https://lucide.dev/icons/",
            target: "_blank", rel: "noopener noreferrer" %>.
    </p>
    <% if event_type.icon.present? && EventType::LUCIDE_VALID_ICONS.include?(event_type.icon) %>
      <div class="form-icon-preview" data-testid="icon-preview">
        <%= lucide_icon(event_type.icon, size: 24) %>
      </div>
    <% end %>
  </div>

  <div class="form-actions">
    <% if event_type.persisted? %>
      <%= link_to "Cancel", event_type_path(event_type), class: "btn btn-secondary" %>
      <span class="btn-divider">|</span>
      <%= f.submit "Update Event Type", class: "btn btn-primary" %>
    <% else %>
      <%= link_to "Cancel", event_types_path, class: "btn btn-secondary" %>
      <span class="btn-divider">|</span>
      <%= f.submit "Create Event Type", class: "btn btn-primary" %>
    <% end %>
  </div>
<% end %>
