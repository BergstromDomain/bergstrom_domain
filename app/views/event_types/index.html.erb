<%# app/views/event_types/index.html.erb %>

<div class="page-header">
  <div class="page-header__top page-header__top--centered">
    <h1 class="page-title">Event Types</h1>
  </div>
  <p class="page-header__subtitle page-header__subtitle--centered">
    Event types are used to classify events into meaningful groups. They are
    intended to be relatively broad, but you can break them down if you want.
  </p>
</div>

<% if @event_types.any? %>
  <div class="data-table-wrapper">
    <table class="data-table" data-testid="event-type-table">
      <colgroup>
        <col style="width: 3.5rem;">
        <col style="width: 14rem;">
        <col>
        <% if authenticated? %><col style="width: 48px;"><% end %>
      </colgroup>
      <thead>
        <tr>
          <th>Icon</th>
          <th>Name</th>
          <th>Description</th>
          <% if authenticated? %><th></th><% end %>
        </tr>
      </thead>
      <tbody>
        <% @event_types.each do |event_type| %>
          <tr data-testid="event-type-row">
            <td class="data-table__icon-cell" data-testid="event-type-icon">
              <%= lucide_icon(event_type.icon, size: 22) %>
            </td>
            <td>
              <%= link_to event_type.name,
                    event_type_path(event_type),
                    class: "data-table__name-link",
                    data: { testid: "event-type-name" } %>
            </td>
            <td class="data-table__description" data-testid="event-type-description">
              <%= event_type.description %>
            </td>
            <% if authenticated? %>
              <td class="data-table__icon-cell" data-testid="event-type-mute-cell">
                <% if @muted_event_type_ids.include?(event_type.id) %>
                  <%= button_to unmute_event_type_path(event_type),
                        method: :delete,
                        class: "icon-button",
                        title: "Unmute #{event_type.name}",
                        data: { testid: "unmute-event-type-#{event_type.id}", turbo: false } do %>
                    <%= lucide_icon("bell-off", size: 18) %>
                  <% end %>
                <% else %>
                  <%= button_to mute_event_type_path(event_type),
                        method: :post,
                        class: "icon-button",
                        title: "Mute #{event_type.name}",
                        data: { testid: "mute-event-type-#{event_type.id}", turbo: false } do %>
                    <%= lucide_icon("bell", size: 18) %>
                  <% end %>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="empty-state" data-testid="empty-state">
    <p>No event types have been added yet.</p>
  </div>
<% end %>
