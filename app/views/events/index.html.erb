<h1>Events</h1>
<% if authenticated? %>
  <%= link_to "Add Event", new_event_path %>
<% end %>

<% if @events.empty? %>
  <p>No events found</p>
<% else %>
  <ul>
    <% @events.each do |event| %>
      <li>
        <%= lucide_icon(event.event_type.icon, size: 20) %>
        <% if event.thumbnail_image.attached? %>
          <%= image_tag event.thumbnail_image, alt: event.title, style: "max-width: 100px;" %>
        <% end %>
        <%= link_to event.title, event_path(event) %>
        <span><%= event.display_date %></span>
      </li>
    <% end %>
  </ul>
<% end %>
