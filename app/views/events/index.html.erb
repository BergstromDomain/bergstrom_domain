<div class="page-header">
  <div class="page-header__top page-header__top--centered">
    <h1 class="page-title">Events</h1>
  </div>
</div>

<nav class="month-nav" data-testid="month-nav">
  <%= link_to "All",
        events_path,
        class: "month-nav__link #{'month-nav__link--active' if @selected_month.nil?}",
        data: { testid: "month-nav-all" } %>
  <% Date::ABBR_MONTHNAMES.compact.each_with_index do |abbr, i| %>
    <% month_num = i + 1 %>
    <%= link_to abbr,
          events_path(month: month_num),
          class: "month-nav__link #{'month-nav__link--active' if @selected_month == month_num}",
          data: { testid: "month-nav-link" } %>
  <% end %>
</nav>

<% if authenticated? %>
  <%# ── Classification filter — single-select, deliberately not multi-select ── %>
  <nav class="classification-nav" data-testid="classification-nav">
    <%= link_to "All",
          events_path(month: @selected_month, event_type_id: @selected_type_id, show_all: @show_all),
          class: "classification-nav__link #{'classification-nav__link--active' if @selected_classification.nil?}",
          data: { testid: "classification-nav-all" } %>
    <% Event.classifications.keys.each do |classification| %>
      <%= link_to classification.humanize,
            events_path(month: @selected_month, event_type_id: @selected_type_id, show_all: @show_all, classification: classification),
            class: "classification-nav__link #{'classification-nav__link--active' if @selected_classification == classification}",
            data: { testid: "classification-nav-link" } %>
    <% end %>
  </nav>

  <%# ── Mute filter — one global toggle bypassing all three mute types ──────── %>
  <nav class="mute-filter-nav" data-testid="mute-filter-nav">
    <%= link_to "Hide muted",
          events_path(month: @selected_month, event_type_id: @selected_type_id, classification: @selected_classification),
          class: "mute-filter-nav__link #{'mute-filter-nav__link--active' unless @show_all}",
          data: { testid: "mute-filter-hide" } %>
    <%= link_to "Show all",
          events_path(month: @selected_month, event_type_id: @selected_type_id, classification: @selected_classification, show_all: true),
          class: "mute-filter-nav__link #{'mute-filter-nav__link--active' if @show_all}",
          data: { testid: "mute-filter-all" } %>
  </nav>
<% end %>

<% if @events.any? %>
  <div class="data-table-wrapper">
    <table class="data-table" data-testid="events-table">
      <colgroup>
        <col style="width: 64px;">
        <col>
        <col style="width: 120px;">
        <col style="width: 56px;">
        <col style="width: 120px;">
        <% if authenticated? %><col style="width: 48px;"><% end %>
      </colgroup>
      <thead>
        <tr>
          <th class="col-thumbnail"></th>
          <th>Title</th>
          <th>Date</th>
          <th>Type</th>
          <th>People</th>
          <% if authenticated? %><th></th><% end %>
        </tr>
      </thead>
      <tbody>
        <% @events.each do |event| %>
          <tr data-testid="event-row">
            <td class="col-thumbnail" data-testid="event-thumbnail">
              <% if event.image.attached? %>
                <%= link_to event_path(event) do %>
                  <%= image_tag event.image.variant(:thumbnail),
                        alt: event.title,
                        class: "table-thumbnail" %>
                <% end %>
              <% else %>
                <%= link_to event_path(event),
                      class: "table-thumbnail-icon",
                      title: event.event_type.name do %>
                  <%= lucide_icon(event.event_type.icon, size: 40) %>
                <% end %>
              <% end %>
            </td>
            <td>
              <%= link_to event.title,
                    event_path(event),
                    class: "data-table__name-link",
                    data: { testid: "event-title" } %>
            </td>
            <td data-testid="event-date">
              <%= event.display_date %>
            </td>
            <td class="data-table__icon-cell" data-testid="event-type-icon">
              <%= link_to events_path(event_type_id: event.event_type.id),
                    title: event.event_type.name do %>
                <%= lucide_icon(event.event_type.icon, size: 20) %>
              <% end %>
            </td>
            <td data-testid="event-people">
              <div class="person-icon-group">
                <% event.people.sort_by { |p| [ p.last_name.to_s.downcase, p.first_name.to_s.downcase ] }.each do |person| %>
                  <%= link_to person_path(person),
                        class: "person-icon-link",
                        title: person.full_name,
                        data: { testid: "event-person" } do %>
                    <% if person.image.attached? %>
                      <%= image_tag person.image.variant(:thumbnail),
                            alt: person.full_name,
                            class: "table-thumbnail table-thumbnail--person" %>
                    <% else %>
                      <span class="table-thumbnail-icon table-thumbnail-icon--person">
                        <%= lucide_icon("user", size: 24) %>
                      </span>
                    <% end %>
                  <% end %>
                <% end %>
              </div>
            </td>
            <% if authenticated? %>
              <td class="data-table__icon-cell" data-testid="event-mute-cell">
                <% if @muted_event_ids.include?(event.id) %>
                  <%= button_to unmute_event_path(event),
                        method: :delete,
                        class: "icon-button",
                        title: "Unmute #{event.title}",
                        data: { testid: "unmute-event-#{event.id}", turbo: false } do %>
                    <%= lucide_icon("bell-off", size: 18) %>
                  <% end %>
                <% else %>
                  <%= button_to mute_event_path(event),
                        method: :post,
                        class: "icon-button",
                        title: "Mute #{event.title}",
                        data: { testid: "mute-event-#{event.id}", turbo: false } do %>
                    <%= lucide_icon("bell", size: 18) %>
                  <% end %>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <div data-testid="pagination-placeholder"></div>
<% else %>
  <div class="empty-state" data-testid="empty-state">
    <p>No events found.</p>
  </div>
<% end %>
