<%# app/views/registrations/new.html.erb %>
<div class="auth-layout">
  <div class="page-header">
    <h1 class="page-title">Sign Up</h1>
  </div>

  <%# ── Info panel ──────────────────────────────────────────────────── %>
  <div class="show-panel show-panel--info" data-testid="sign-up-info">
    <%= lucide_icon "info", size: 18, class: "show-panel--info__icon" %>
    <div>
      <p>As a registered user you will be able to:</p>
      <ul>
        <li>Make comments on blog posts</li>
        <li>Ask recipe questions to the chef</li>
        <li>Like and interact with photos</li>
      </ul>
      <p>
        Anonymous comments are not allowed on this website. First name, last name,
        and a profile image are mandatory so that other users know who they are
        interacting with.
      </p>
      <p>Once you have submitted your request:</p>
      <ul>
        <li>You will be asked to verify your email address</li>
        <li>Your request will be reviewed — you would normally receive a reply within 24 hours</li>
        <li>You can continue to use the website as a guest in the meantime</li>
      </ul>
    </div>
  </div>

  <%# ── Errors ──────────────────────────────────────────────────────── %>
  <% if @user.errors.any? %>
    <div class="form-errors" data-testid="sign-up-errors">
      <p class="form-errors__heading">
        <%= pluralize(@user.errors.count, "error") %> prevented your request from being submitted:
      </p>
      <ul class="form-errors__list">
        <% @user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: sign_up_path, model: @user do |f| %>
    <div class="show-panel" data-testid="sign-up-panel">

      <%# ── First name ─────────────────────────────────────────────── %>
      <div class="form-field">
        <%= f.label :first_name, "First name", class: "sr-only" %>
        <h3 class="show-meta-cell__label">First name</h3>
        <%= f.text_field :first_name,
              autocomplete: "given-name",
              class: "form-control",
              data: { testid: "sign-up-first-name" } %>
      </div>

      <%# ── Last name ──────────────────────────────────────────────── %>
      <div class="form-field">
        <%= f.label :last_name, "Last name", class: "sr-only" %>
        <h3 class="show-meta-cell__label">Last name</h3>
        <%= f.text_field :last_name,
              autocomplete: "family-name",
              class: "form-control",
              data: { testid: "sign-up-last-name" } %>
      </div>

      <%# ── Profile image ──────────────────────────────────────────── %>
      <div class="form-field" data-testid="sign-up-profile-image">
        <label class="sr-only" for="profile-image-input">Profile image</label>
        <h3 class="show-meta-cell__label">Profile image</h3>
        <%= f.file_field :profile_image,
              id: "profile-image-input",
              accept: "image/*",
              class: "form-control" %>
      </div>

      <%# ── Email address ──────────────────────────────────────────── %>
      <div class="form-field">
        <%= f.label :email_address, "Email address", class: "sr-only" %>
        <h3 class="show-meta-cell__label">Email address</h3>
        <%= f.email_field :email_address,
              placeholder: "you@example.com",
              autocomplete: "email",
              class: "form-control",
              data: { testid: "sign-up-email" } %>
      </div>

      <%# ── Password ───────────────────────────────────────────────── %>
      <div class="form-field">
        <%= f.label :password, "Password", class: "sr-only" %>
        <h3 class="show-meta-cell__label">Password</h3>
        <div class="password-field-wrapper"
             data-controller="password-visibility"
             data-testid="sign-up-password-wrapper">
          <%= f.password_field :password,
                autocomplete: "new-password",
                class: "form-control",
                data: { "password-visibility-target": "input",
                        testid: "sign-up-password" } %>
          <button type="button"
                  class="password-toggle"
                  aria-label="Show password"
                  data-action="click->password-visibility#toggle"
                  data-password-visibility-target="button">
            <%= lucide_icon "eye", size: 16 %>
          </button>
        </div>
      </div>

      <%# ── Password confirmation ──────────────────────────────────── %>
      <div class="form-field">
        <%= f.label :password_confirmation, "Password confirmation", class: "sr-only" %>
        <h3 class="show-meta-cell__label">Password confirmation</h3>
        <div class="password-field-wrapper"
             data-controller="password-visibility"
             data-testid="sign-up-password-confirmation-wrapper">
          <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                class: "form-control",
                data: { "password-visibility-target": "input",
                        testid: "sign-up-password-confirmation" } %>
          <button type="button"
                  class="password-toggle"
                  aria-label="Show password"
                  data-action="click->password-visibility#toggle"
                  data-password-visibility-target="button">
            <%= lucide_icon "eye", size: 16 %>
          </button>
        </div>
      </div>

      <%# ── Message to admin ───────────────────────────────────────── %>
      <div class="form-field">
        <%= f.label :message_to_admin, "Message to admin", class: "sr-only" %>
        <h3 class="show-meta-cell__label">
          Message to admin
          <span class="show-meta-cell__label--optional">(optional)</span>
        </h3>
        <%= f.text_area :message_to_admin,
              rows: 4,
              placeholder: "Let us know how you heard about this site, or anything else you'd like to add to your request.",
              class: "form-control",
              data: { testid: "sign-up-message" } %>
      </div>

    </div>

    <%# ── Actions ────────────────────────────────────────────────────── %>
    <div class="show-panel show-panel--actions" style="justify-content: space-between;">
      <%= link_to root_path, class: "btn btn-secondary", data: { testid: "sign-up-cancel" } do %>
        <%= lucide_icon "circle-x", size: 16 %>
        Cancel
      <% end %>
      <button type="submit" class="btn btn-primary-action" data-testid="sign-up-submit">
        <%= lucide_icon "user-plus", size: 16 %>
        Sign Up
      </button>
    </div>

  <% end %>
</div>
