<%# app/views/passwords/new.html.erb %>
<div class="auth-layout">
  <div class="page-header">
    <h1 class="page-title">Forgot Password</h1>
  </div>

  <%= form_with url: passwords_path do |form| %>
    <div class="show-panel" data-testid="forgot-password-panel">
      <div class="form-field">
        <label class="sr-only" for="email_address">Email address</label>
        <h3 class="show-meta-cell__label">Email address</h3>
        <%= form.email_field :email_address,
              id: "email_address",
              required: true,
              autofocus: true,
              autocomplete: "email",
              placeholder: "you@example.com",
              data: { testid: "email-field" } %>
      </div>

      <p class="form-helper-text" data-testid="reset-helper-text">
        Enter your email address and we'll send you a link to reset your password.
      </p>
    </div>

    <div class="show-panel show-panel--actions" style="justify-content: space-between;">
      <%= link_to new_session_path,
            class: "btn btn-secondary",
            data: { testid: "cancel-link" } do %>
        <%= lucide_icon("circle-x", size: 16) %> Cancel
      <% end %>

      <button type="submit" class="btn btn-primary-action" data-testid="send-reset-link-button">
        <%= lucide_icon "mail", size: 18 %>
        Send Reset Link
      </button>
    </div>
  <% end %>
</div>
