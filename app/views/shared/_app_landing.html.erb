<%#
  Reusable app landing page partial.

  Locals:
    app_name   - String. Used for hero alt text only; the caller owns its own <h1>.
    hero_image - String. Any filename image_tag can resolve from app/assets/images.
    about      - Array of Strings. One or more paragraphs answering "what is this app".

  Deliberately has no teaser/feature links — once the left nav is showing
  for an app (which it always is, per Navigable), those links just
  duplicate what's already one click away in the sidebar.
%>
<div class="split-layout" data-testid="app-landing">
  <div class="split-layout__media">
    <%= image_tag hero_image, class: "split-layout__media-image", alt: "#{app_name} preview" %>
  </div>

  <div class="split-layout__cards" data-testid="app-landing-about">
    <% about.each_with_index do |paragraph, index| %>
      <div class="show-panel about-card" data-testid="app-landing-about-<%= index + 1 %>">
        <p><%= paragraph %></p>
      </div>
    <% end %>
  </div>
</div>
