<%# app/views/layouts/_top_nav.html.erb %>
<nav class="top-nav" data-testid="top-nav">

  <div class="top-nav__links">

    <%= link_to "Home", root_path, class: "top-nav__link" %>

    <%= render "layouts/dropdown",
               label: "Apps",
               items: [
                 { label: "Event Tracker", path: events_path },
                 { label: "Blog Posts",    path: blog_posts_path }
               ] %>

    <%= render "layouts/dropdown",
               label: "Info",
               items: [
                 { label: "About",   path: about_path },
                 { label: "Contact", path: contact_path }
               ] %>

    <% if authenticated? && current_user.system_admin? %>
      <%= render "layouts/dropdown",
                 label: "System Admin",
                 items: [
                   { label: "User Management", path: nil },
                   { label: "App Management",  path: nil }
                 ] %>
    <% end %>

  </div>

  <div class="top-nav__auth">
    <% if authenticated? %>
      <div class="dropdown" data-controller="dropdown" data-testid="user-thumbnail-dropdown">
        <button class="top-nav__link top-nav__dropdown-trigger"
                data-action="click->dropdown#toggle"
                data-testid="user-thumbnail-button"
                aria-label="User Thumbnail">
          <%= lucide_icon "circle-user-round", size: 24 %>
          <%= lucide_icon "chevron-down", class: "dropdown__chevron" %>
        </button>
        <ul class="dropdown__menu" data-dropdown-target="menu">
          <li>
            <%= link_to "User Settings", settings_path, class: "dropdown__item", data: { testid: "user-settings-link" } %>
          </li>
          <li>
            <%= button_to session_path,
                  method: :delete,
                  class: "dropdown__item dropdown__item--signout",
                  data: { testid: "sign-out-button", turbo: false } do %>
              Sign Out
            <% end %>
          </li>
        </ul>
      </div>
    <% else %>
      <%= link_to new_session_path,
            class: "top-nav__button top-nav__button--login",
            data: { testid: "top-nav-sign-in" } do %>
        <%= lucide_icon "log-in", size: 16 %>
        Sign In
      <% end %>
    <% end %>
  </div>
</nav>
