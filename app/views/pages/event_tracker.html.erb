<div class="page-header page-header--centered">
  <div class="page-header__top">
    <h1 class="page-title">Event Tracker</h1>
  </div>
  <p class="page-header__subtitle">
    Track people, events, and the connections between them.
  </p>
</div>

<%= render "shared/app_landing",
      app_name: "Event Tracker",
      hero_image: "event-tracker-hero.png",
      about: [
        "The Event Tracker app lets you track basic life events — " \
        "birthdays, graduations, weddings — for family and friends.",
